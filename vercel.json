{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "app/api/enhance/route.ts": { "maxDuration": 90 },
    "app/api/convert/route.ts": { "maxDuration": 90 }
  },
  "env": {
    "NEXTAUTH_URL": "https://mathscribe.vercel.app"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
